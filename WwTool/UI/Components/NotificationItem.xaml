<UserControl
    x:Class="WwTool.UI.Components.NotificationItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    x:Name="Root"
    Width="280"
    Margin="0,0,0,10"
    Opacity="0">
    <UserControl.Resources>
        <Storyboard x:Key="ShowAndHideStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="Root"
                Storyboard.TargetProperty="Opacity"
                From="0.0"
                To="1.0"
                Duration="0:0:0.3" />
            <ThicknessAnimation
                DecelerationRatio="0.5"
                Storyboard.TargetName="Root"
                Storyboard.TargetProperty="Margin"
                From="100,0,-100,10"
                To="0,0,0,10"
                Duration="0:0:0.3" />
            <DoubleAnimation
                BeginTime="0:0:2.5"
                Storyboard.TargetName="Root"
                Storyboard.TargetProperty="Opacity"
                From="1.0"
                To="0.0"
                Duration="0:0:0.3" />
        </Storyboard>

        <Storyboard x:Key="FastFadeOutStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="Root"
                Storyboard.TargetProperty="Opacity"
                To="0.0"
                Duration="0:0:0.15" />
        </Storyboard>
    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:ControlStoryboardAction ControlStoryboardOption="Play" Storyboard="{StaticResource ShowAndHideStoryboard}" />
        </i:EventTrigger>

        <i:StoryboardCompletedTrigger Storyboard="{StaticResource ShowAndHideStoryboard}">
            <i:InvokeCommandAction Command="{Binding CloseCommand}" />
        </i:StoryboardCompletedTrigger>
    </i:Interaction.Triggers>

    <Border
        Background="{DynamicResource CardBgBrush}"
        BorderBrush="{DynamicResource StrokeBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Cursor="Hand">

        <i:Interaction.Triggers>
            <i:EventTrigger EventName="MouseLeftButtonDown">
                <i:ControlStoryboardAction ControlStoryboardOption="Stop" Storyboard="{StaticResource ShowAndHideStoryboard}" />
                <i:ControlStoryboardAction ControlStoryboardOption="Play" Storyboard="{StaticResource FastFadeOutStoryboard}" />
            </i:EventTrigger>

            <i:StoryboardCompletedTrigger Storyboard="{StaticResource FastFadeOutStoryboard}">
                <i:InvokeCommandAction Command="{Binding CloseCommand}" />
            </i:StoryboardCompletedTrigger>
        </i:Interaction.Triggers>

        <Border.Effect>
            <DropShadowEffect
                BlurRadius="12"
                Direction="270"
                Opacity="0.06"
                ShadowDepth="2"
                Color="{DynamicResource ShadowLightColor}" />
        </Border.Effect>

        <Grid Margin="12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Ellipse
                Width="8"
                Height="8"
                Margin="0,5,10,0"
                VerticalAlignment="Top"
                Fill="{Binding ThemeBrush}" />

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock
                    Margin="0,0,0,2"
                    FontSize="13"
                    Style="{StaticResource TitleTextStyle}"
                    Text="{Binding Title}" />
                <TextBlock
                    LineHeight="16"
                    Style="{StaticResource CaptionTextStyle}"
                    Text="{Binding Message}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
<UserControl
    x:Class="WwTool.UI.Views.Dialogs.AlertView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="clr-namespace:WwTool.Common.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="clr-namespace:Microsoft.Xaml.Behaviors;assembly=Microsoft.Xaml.Behaviors"
    xmlns:local="clr-namespace:WwTool.UI.Views.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:utils="clr-namespace:WwTool.Common.Utils"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="SizeToContent" Value="WidthAndHeight" />
            <Setter Property="ResizeMode" Value="NoResize" />
            <Setter Property="WindowStyle" Value="None" />
            <Setter Property="AllowsTransparency" Value="True" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </prism:Dialog.WindowStyle>

    <Border
        MinWidth="280"
        MinHeight="140"
        Padding="24"
        Background="{DynamicResource CardBgBrush}"
        BorderBrush="{DynamicResource StrokeBrush}"
        BorderThickness="1"
        CornerRadius="12">

        <Border.Effect>
            <DropShadowEffect
                BlurRadius="30"
                Opacity="0.2"
                ShadowDepth="5"
                Color="{DynamicResource ShadowDarkColor}" />
        </Border.Effect>

        <i:Interaction.Behaviors>
            <b:DragWindowBehavior />
        </i:Interaction.Behaviors>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="0,0,0,10"
                BorderBrush="{DynamicResource UnderLineBrush}"
                BorderThickness="0,0,0,2">
                <TextBlock HorizontalAlignment="Left" Style="{StaticResource TitleTextStyle}" Text="{Binding Title}" />
            </Border>

            <TextBlock
                Grid.Row="1"
                Margin="0,16,0,24"
                FontSize="{StaticResource FontSizeBase}"
                Style="{StaticResource SubtitleTextStyle}"
                Text="{Binding Message}"
                TextWrapping="Wrap" />

            <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Width="68"
                    Height="30"
                    Margin="0,0,12,0"
                    Command="{Binding CancelCommand}"
                    Content="{Binding Path=[Common_Cancel], Source={x:Static utils:LanguageManager.Instance}}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource CancelButtonStyle}" TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowCancel}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button
                    Height="30"
                    MinWidth="68"
                    Command="{Binding OkCommand}"
                    Content="{Binding Path=[Common_Ok], Source={x:Static utils:LanguageManager.Instance}}"
                    Style="{StaticResource OkButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
<UserControl
    x:Class="WwTool.UI.Views.IndexView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:WwTool.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:extensions="clr-namespace:WwTool.Extensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:WwTool.Common.Utils"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:TimeStampToDateStringConverter x:Key="TimeStampToDateString" />
        <converters:TimeStampToTimeString x:Key="TimeStampToTimeString" />
        <converters:LongToStringConverter x:Key="LongToString" />
        <converters:ImageConverter x:Key="ImageConverter" />
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <ScaleTransform x:Name="PageTransform" ScaleX="0.8" ScaleY="0.8" />
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation
                        Storyboard.TargetProperty="Opacity"
                        From="0"
                        To="1"
                        Duration="0:0:0.35" />
                    <DoubleAnimation
                        Storyboard.TargetName="PageTransform"
                        Storyboard.TargetProperty="ScaleY"
                        From="0.8"
                        To="1"
                        Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseInOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="PageTransform"
                        Storyboard.TargetProperty="ScaleX"
                        From="0.8"
                        To="1"
                        Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseInOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{DynamicResource UnderLineBrush}" BorderThickness="0,0,0,2">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Margin="20,5"
                    HorizontalAlignment="Left"
                    Style="{StaticResource HeaderTextStyle}"
                    Text="{Binding Path=[Index_Home], Source={x:Static utils:LanguageManager.Instance}}" />
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        Height="30"
                        Margin="0,0,20,0"
                        HorizontalAlignment="Right"
                        Command="{Binding ShowLoginDialogCommand}"
                        Content="{Binding Path=[Index_AddAccount], Source={x:Static utils:LanguageManager.Instance}}"
                        Foreground="{DynamicResource ButtonTextBrush}"
                        Style="{StaticResource OkButtonStyle}"
                        Tag="{StaticResource AddImage}" />
                    <Button
                        Height="30"
                        Margin="0,0,20,0"
                        HorizontalAlignment="Right"
                        Command="{Binding RefreshLocalAccountCommand}"
                        Content="{Binding Path=[Index_RefreshAccountList], Source={x:Static utils:LanguageManager.Instance}}"
                        Tag="{StaticResource RefreshImage}" />
                </StackPanel>

            </Grid>
        </Border>
        <Canvas x:Name="DragCanvas" Grid.Row="1" Background="Transparent">
            <Border
                x:Name="RoleCard"
                Canvas.Top="5"
                Canvas.Right="5"
                MinWidth="320"
                MouseLeftButtonDown="OnRoleCardMouseDown"
                MouseLeftButtonUp="OnRoleCardMouseUp"
                MouseMove="OnRoleCardMouseMove">
                <Grid Margin="0,10,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border
                        Grid.Row="0"
                        Padding="10"
                        Background="{DynamicResource CardBgBrush}"
                        BorderBrush="{DynamicResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" BorderBrush="{DynamicResource UnderLineBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Vertical">
                                        <Image
                                            Width="60"
                                            Height="60"
                                            Margin="0,5"
                                            Source="{Binding SelectedUser.IconPath, Converter={StaticResource ImageConverter}}" />

                                    </StackPanel>


                                    <Grid Grid.Column="1">
                                        <StackPanel
                                            Margin="5,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Orientation="Vertical">
                                            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                                                <TextBlock
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    FontSize="15"
                                                    FontWeight="Bold"
                                                    Text="{Binding RoleName}" />
                                                <TextBlock
                                                    Margin="5,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    FontSize="11"
                                                    FontWeight="Bold"
                                                    Text="{Binding Level, StringFormat='LV.{0}', TargetNullValue='LV.---'}" />
                                            </StackPanel>

                                            <TextBlock
                                                Margin="2,2,0,5"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                FontSize="9"
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="{Binding Uid, StringFormat='UID: {0}', TargetNullValue='UID: ---'}" />
                                        </StackPanel>

                                        <Button
                                            Width="30"
                                            Height="30"
                                            Margin="0,5,5,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Command="{Binding RefreshInfoCommand}"
                                            Foreground="{DynamicResource ButtonTextBrush}"
                                            Style="{StaticResource ImageButtonStyle}"
                                            Tag="{DynamicResource RefreshImage}" />

                                    </Grid>
                                </Grid>
                            </Border>


                            <Border Grid.Row="1" BorderBrush="{DynamicResource UnderLineBrush}" BorderThickness="0,0,0,1">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto" />
                                        <RowDefinition Height="auto" />
                                        <RowDefinition Height="auto" />
                                        <RowDefinition Height="auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto" />
                                        <ColumnDefinition Width="auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Margin="0,10,0,0"
                                        Orientation="Horizontal">
                                        <StackPanel Orientation="Vertical">
                                            <Image Width="40" Height="40" Source="{StaticResource EnergyImage}" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="11"
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="{Binding Path=[Index_CrystalSheet], Source={x:Static utils:LanguageManager.Instance}}" />
                                        </StackPanel>
                                        <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Style="{StaticResource BaseTextBlockStyle}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} / {1}">
                                                        <Binding Path="Energy" />
                                                        <Binding Path="MaxEnergy" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource TimeStampToTimeString}">
                                                        <Binding Path="EnergyRecoverTime" />
                                                        <Binding Path="CurrentLanguage" Source="{x:Static utils:LanguageManager.Instance}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="10,10,0,0"
                                        Orientation="Horizontal">
                                        <StackPanel Orientation="Vertical">
                                            <Image Width="40" Height="40" Source="{StaticResource StorgeEnergyImage}" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="11"
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="{Binding Path=[Index_CrystalElement], Source={x:Static utils:LanguageManager.Instance}}" />
                                        </StackPanel>
                                        <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Style="{StaticResource BaseTextBlockStyle}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} / {1}">
                                                        <Binding Path="StorgeEnergy" />
                                                        <Binding Path="MaxStorgeEnergy" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource TimeStampToTimeString}">
                                                        <Binding Path="StorgeEnergyRecoverTime" />
                                                        <Binding Path="CurrentLanguage" Source="{x:Static utils:LanguageManager.Instance}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal">
                                        <StackPanel Orientation="Vertical">
                                            <Image Width="40" Height="40" Source="{StaticResource LivenessImage}" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="11"
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="{Binding Path=[Index_Active], Source={x:Static utils:LanguageManager.Instance}}" />
                                        </StackPanel>
                                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center" Orientation="Vertical">
                                            <TextBlock HorizontalAlignment="Center" FontSize="16" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style BasedOn="{StaticResource TitleTextStyle}" TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding Path=[Index_Locked], Source={x:Static utils:LanguageManager.Instance}}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LivenessUnlock}" Value="True">
                                                                <Setter Property="Text">
                                                                    <Setter.Value>
                                                                        <MultiBinding StringFormat="{}{0}">
                                                                            <Binding Path="Liveness" />
                                                                        </MultiBinding>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <ProgressBar
                                                Width="200"
                                                extensions:ProgressBarExtensions.SmoothValue="{Binding Liveness}"
                                                Background="{DynamicResource HoverBgBrush}"
                                                Maximum="{Binding LivenessMaxCount}"
                                                Minimum="0"
                                                Style="{StaticResource ExpBarStyle}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal">
                                        <StackPanel Orientation="Vertical">
                                            <Image
                                                Width="30"
                                                Height="30"
                                                Margin="-2,0,0,0"
                                                HorizontalAlignment="Center"
                                                Source="{StaticResource BattlePassImage}" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="11"
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="{Binding Path=[Index_Radio], Source={x:Static utils:LanguageManager.Instance}}" />
                                        </StackPanel>
                                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center" Orientation="Vertical">
                                            <DockPanel HorizontalAlignment="Stretch">
                                                <TextBlock
                                                    HorizontalAlignment="Left"
                                                    DockPanel.Dock="Left"
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="{Binding Path=[Index_ThisWeek], Source={x:Static utils:LanguageManager.Instance}}" />
                                                <TextBlock HorizontalAlignment="Right" DockPanel.Dock="Right" Style="{StaticResource CaptionTextStyle}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} / {1}">
                                                            <Binding Path="BpWeekUp" />
                                                            <Binding Path="BpWeekMaxUp" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DockPanel>

                                            <ProgressBar
                                                Width="200"
                                                extensions:ProgressBarExtensions.SmoothValue="{Binding Liveness}"
                                                Background="{DynamicResource HoverBgBrush}"
                                                Maximum="{Binding BpExpLimit}"
                                                Minimum="0"
                                                Style="{StaticResource ExpBarStyle}"
                                                Value="{Binding BpExp}">
                                                <ProgressBar.Tag>
                                                    <TextBlock FontSize="12" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style BasedOn="{StaticResource TitleTextStyle}" TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding Path=[Index_Locked], Source={x:Static utils:LanguageManager.Instance}}" />

                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding BpIsUnlock}" Value="True">
                                                                        <Setter Property="Text">
                                                                            <Setter.Value>
                                                                                <MultiBinding StringFormat="{}LV.{0}">
                                                                                    <Binding Path=" BpLevel" />
                                                                                </MultiBinding>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </ProgressBar.Tag>
                                            </ProgressBar>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        Margin="0,10,0,5"
                                        Orientation="Horizontal">
                                        <StackPanel Orientation="Vertical">
                                            <Image Width="40" Height="40" Source="{StaticResource WeeklyInstImage}" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="11"
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="{Binding Path=[Index_WeeklyBoss], Source={x:Static utils:LanguageManager.Instance}}" />
                                        </StackPanel>
                                        <TextBlock
                                            Margin="10,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Style="{StaticResource BaseTextBlockStyle}"
                                            Text="{Binding WeeklyInstCount, StringFormat={}{0} / 3}" />
                                    </StackPanel>


                                    <StackPanel
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Margin="0,10,0,5"
                                        Orientation="Horizontal">
                                        <StackPanel Orientation="Vertical">
                                            <Rectangle Width="40" Height="40" Fill="{DynamicResource TextMainBrush}">
                                                <Rectangle.OpacityMask>
                                                    <ImageBrush ImageSource="{StaticResource RoleImage}" Stretch="Uniform" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                            <TextBlock FontSize="11" Style="{StaticResource CaptionTextStyle}" Text="{Binding Path=[Index_OwnedRoles], Source={x:Static utils:LanguageManager.Instance}}" />
                                        </StackPanel>
                                        <StackPanel
                                            Margin="10,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Style="{StaticResource BaseTextBlockStyle}"
                                                Text="{Binding RoleNum}" />
                                            <TextBlock
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Style="{StaticResource BaseTextBlockStyle}"
                                                Text="{Binding Path=[Unit_Role], Source={x:Static utils:LanguageManager.Instance}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>


                            <Grid Grid.Row="2" Margin="0,10,0,0">
                                <StackPanel Margin="5" HorizontalAlignment="Center" Orientation="Horizontal">
                                    <StackPanel Margin="10,0,0,0" Orientation="Vertical">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding ActiceDays}" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="{Binding Path=[Index_ActiveDays], Source={x:Static utils:LanguageManager.Instance}}" />
                                    </StackPanel>
                                    <StackPanel Margin="10,0,0,0" Orientation="Vertical">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding CreateTime, Converter={StaticResource TimeStampToDateString}}" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="{Binding Path=[Index_CreateDate], Source={x:Static utils:LanguageManager.Instance}}" />
                                    </StackPanel>
                                    <StackPanel Margin="10,0,10,0" Orientation="Vertical">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding WorldLevel}" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="{Binding Path=[Index_SolaLevel], Source={x:Static utils:LanguageManager.Instance}}" />
                                    </StackPanel>
                                    <StackPanel Margin="10,0,10,0" Orientation="Vertical">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Region}" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="{Binding Path=[Index_Server], Source={x:Static utils:LanguageManager.Instance}}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Margin="0,10,0,0"
                        Padding="10"
                        Background="{DynamicResource CardBgBrush}"
                        BorderBrush="{DynamicResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock FontSize="14" Style="{StaticResource TitleTextStyle}" Text="{Binding Path=[Index_SelectRole], Source={x:Static utils:LanguageManager.Instance}}" />
                                <ComboBox
                                    Margin="10,0,0,0"
                                    ItemsSource="{Binding Users}"
                                    SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                                    Style="{StaticResource {x:Type ComboBox}}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center" Style="{StaticResource BaseTextBlockStyle}" Text="{Binding Uid}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Center">
                                <Button
                                    Height="25"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Command="{Binding LoadLocalAccountInfoCommand}"
                                    Content="{Binding Path=[Index_Load], Source={x:Static utils:LanguageManager.Instance}}"
                                    Style="{StaticResource {x:Type Button}}"
                                    Tag="{StaticResource LoadImage}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Canvas>

    </Grid>
</UserControl>

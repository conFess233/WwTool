<UserControl
    x:Class="WwTool.UI.Views.AboutView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:WwTool.Common.Utils"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.RenderTransform>
        <ScaleTransform x:Name="PageTransform" ScaleX="0.8" ScaleY="0.8" />
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation
                        Storyboard.TargetProperty="Opacity"
                        From="0"
                        To="1"
                        Duration="0:0:0.35" />
                    <DoubleAnimation
                        Storyboard.TargetName="PageTransform"
                        Storyboard.TargetProperty="ScaleY"
                        From="0.8"
                        To="1"
                        Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseInOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="PageTransform"
                        Storyboard.TargetProperty="ScaleX"
                        From="0.8"
                        To="1"
                        Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseInOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="1">
            <Border BorderBrush="{DynamicResource UnderLineBrush}" BorderThickness="0,0,0,2">
                <TextBlock Margin="10" Style="{StaticResource HeaderTextStyle}" Text="{Binding Path=[Nav_About], Source={x:Static utils:LanguageManager.Instance}}" />
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="20" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border
                    Margin="0,0,0,20"
                    Padding="20"
                    Background="{DynamicResource CardBgBrush}"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,10"
                            FontSize="24"
                            Style="{StaticResource TitleTextStyle}"
                            Text="{Binding Path=[About_Title], Source={x:Static utils:LanguageManager.Instance}}" />
                        <TextBlock FontWeight="Bold" Style="{StaticResource BaseTextBlockStyle}" Text="{Binding Path=[About_Version], Source={x:Static utils:LanguageManager.Instance}, StringFormat='{}{0}: '}" />
                        <TextBlock Margin="20,5,0,10" Style="{StaticResource BaseTextBlockStyle}" Text="{Binding Version}" />

                        <TextBlock FontWeight="Bold" Style="{StaticResource BaseTextBlockStyle}" Text="{Binding Path=[About_Author], Source={x:Static utils:LanguageManager.Instance}, StringFormat='{}{0}: '}" />
                        <TextBlock Margin="20,5,0,10" Style="{StaticResource BaseTextBlockStyle}" Text="{Binding Author}" />

                        <TextBlock FontWeight="Bold" Style="{StaticResource BaseTextBlockStyle}" Text="{Binding Path=[About_Github], Source={x:Static utils:LanguageManager.Instance}, StringFormat='{}{0}: '}" />
                        <Button
                            Margin="20,5,0,10"
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Command="{Binding OpenLinkCommand}"
                            CommandParameter="https://github.com/conFess233/WwTool"
                            Content="https://github.com/conFess233/WwTool"
                            Style="{x:Null}" />
                    </StackPanel>
                </Border>

                <Border Padding="20" Background="{DynamicResource CardBgBrush}" CornerRadius="10">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,10"
                            FontSize="20"
                            Style="{StaticResource TitleTextStyle}"
                            Text="{Binding Path=[About_Disclaimer], Source={x:Static utils:LanguageManager.Instance}}" />
                        <TextBlock
                            Margin="10,0,0,0"
                            Style="{StaticResource BaseTextBlockStyle}"
                            Text="{Binding Path=[About_DisclaimerText], Source={x:Static utils:LanguageManager.Instance}}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="ThemePickerStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />

        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Margin" Value="0,0,16,12" />
                    <Setter Property="ToolTip" Value="{Binding Content, RelativeSource={RelativeSource Self}}" />

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Grid Width="36" Height="36" Background="Transparent">
                                    <Ellipse
                                        x:Name="OuterRing"
                                        Width="36"
                                        Height="36"
                                        Stroke="Transparent"
                                        StrokeThickness="2" />

                                    <Ellipse
                                        x:Name="InnerCircle"
                                        Width="28"
                                        Height="28"
                                        Fill="{TemplateBinding Background}"
                                        Stroke="{DynamicResource StrokeBrush}"
                                        StrokeThickness="1">
                                        <Ellipse.Effect>
                                            <DropShadowEffect
                                                BlurRadius="4"
                                                Direction="270"
                                                Opacity="0.15"
                                                ShadowDepth="1" />
                                        </Ellipse.Effect>
                                    </Ellipse>
                                </Grid>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="OuterRing" Property="Stroke" Value="{DynamicResource TextBoxStrokeBrush}" />
                                    </Trigger>

                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="OuterRing" Property="Stroke" Value="{DynamicResource CheckedBrush}" />
                                        <Setter TargetName="InnerCircle" Property="Width" Value="24" />
                                        <Setter TargetName="InnerCircle" Property="Height" Value="24" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>